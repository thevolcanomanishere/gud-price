{
  "name": "@hypotenuselabs/ts-chainlink-datafeed",
  "license": "MIT",
  "version": "1.0.0",
  "description": "Zero-dependency Typescript library for reading Chainlink price feeds",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "sideEffects": false,
  "exports": {
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hyplabs/ts-chainlink-datafeed.git"
  },
  "keywords": [
    "chainlink",
    "datafeed",
    "price-feed",
    "typescript",
    "zero-dependency"
  ],
  "author": "Alex McGonagle",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "updateAllFeeds": "tsx ./scraper/playwright.ts && prettier --write ./src/dataFeeds/*.ts",
    "build": "rm -rf dist && tsup src/index.ts --minify --format cjs,esm --dts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0",
    "vitest": "^4.1.2"
  },
  "bugs": {
    "url": "https://github.com/hyplabs/ts-chainlink-datafeed/issues"
  },
  "homepage": "https://github.com/hyplabs/ts-chainlink-datafeed#readme",
  "directories": {
    "example": "example"
  }
}
